#!/usr/bin/env bash
#
# aiworks — root launcher for the workspace CLI (scripts/aiworks).
#
# Lets everyone run `./aiworks <cmd>` straight from the workspace root:
#   ./aiworks setup · ./aiworks run · ./aiworks sync · …
#
# Optional: symlink it onto your PATH to drop the ./ and run it from anywhere —
#   ln -s "$PWD/aiworks" ~/.local/bin/aiworks
# The symlink chain is resolved below, so the CLI always finds THIS workspace.
#
set -uo pipefail
src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
exec "$(cd -P "$(dirname "$src")" && pwd)/scripts/aiworks" "$@"
