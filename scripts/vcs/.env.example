# Copy to `.env` (this dir) and fill in if needed. The .env is git-ignored.
#
# The provider is normally AUTO-DETECTED from the origin remote host (github.com ->
# github, gitlab.* -> gitlab). Set this only to override the detection.
#
# github | gitlab
# VCS_PROVIDER=gitlab

# Auth is handled by the provider CLI itself, not this file:
#   GitHub:  gh auth login   (or a GH_TOKEN / GITHUB_TOKEN env var)
#   GitLab:  glab auth login  (or a GITLAB_TOKEN env var; GITLAB_HOST for self-managed)
#
# NB: auto-merge is NOT configured here. Whether the dev-cycle squash-merges automatically
# is policy, set in workspace.config.yaml (vcs.auto_merge + per-repo auto_merge). merge-pr.sh
# is the low-level primitive and always merges when invoked.
