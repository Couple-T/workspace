# Copy to `.env` (this dir) and fill in. The .env is git-ignored.
# Pick ONE tracker; only that provider's block needs values.

# notion | jira | linear
TRACKER_PROVIDER=notion

# ── Notion ──────────────────────────────────────────────────────────────────
# Internal integration token — https://www.notion.so/my-integrations
#   1. Create an internal integration.
#   2. Capabilities: "Read content", "Read comments", "Update content",
#      "Insert content" (to auto-create a missing ticket), "Insert comments",
#      and (optional, for commenter names) "Read user information".
#   3. Open your tasks database → ••• → Connections → add the integration.
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The tasks database id (the 32-hex id from the database URL).
NOTION_DB_ID=
# The unique-id property holding the ticket number (default: "Task ID").
# NOTION_ID_PROP=Task ID
# NOTION_VERSION=2022-06-28
# Property NAMES if your workspace differs from the defaults:
# NOTION_PROP_STATUS=Status
# NOTION_PROP_PRIORITY=Priority
# NOTION_PROP_EFFORT=Effort level
# Estimation point fields (NUMBER properties). /estimate-ticket writes the Dev/QA
# split here instead of only in a comment. Create them on the tasks DB if missing.
# NOTION_PROP_DEV_POINTS=Developer Points
# NOTION_PROP_QA_POINTS=QA Points
# NOTION_PROP_TITLE=Task name
# NOTION_PROP_DESCRIPTION=Description
# NOTION_PROP_TYPE=Task type     # multi_select; used by find-tickets.sh --type / --issuetype
# NOTION_STATUS_DONE=Done        # the "done" status name; used by find-tickets.sh --open
# Child-issue mapping for upsert-ticket-details.sh --parent / --component / --link
# (e.g. /qa-subtasks). Parent + links are RELATION properties; component is a multi_select.
# Leave a name empty to disable that flag (the adapter warns instead of dropping silently).
# NOTION_PROP_PARENT=Parent item    # relation → the parent (sub-item), set by --parent
# NOTION_PROP_COMPONENT=Component   # multi_select → --component
# NOTION_PROP_LINKS=                # relation → --link targets; OFF by default (Notion has no typed links)

# ── Jira (Cloud) ─────────────────────────────────────────────────────────────
# Basic auth with your account email + an API token.
# Create a token: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=you@your-org.com
# JIRA_API_TOKEN=xxxxxxxxxxxxxxxxxxxx
# Project key — lets a bare number (e.g. 123) expand to KEY-123 (e.g. APP-123),
# and is the project new issues are created in (ref "new").
# JIRA_PROJECT_KEY=APP
# Issue type used when creating a new issue (ref "new"). Default: Task.
# JIRA_DEFAULT_ISSUETYPE=Task
# Optional: sub-task issue type NAME for upsert-ticket-details.sh --subtask (e.g. /qa-subtasks).
# When unset, --subtask resolves the project's sub-task type from the Jira API; set this to
# skip that lookup or to pin a specific name.
# JIRA_SUBTASK_ISSUETYPE=Sub-task
# Optional: custom-field id mapped to --effort (e.g. story points).
# JIRA_EFFORT_FIELD=customfield_10016
# Optional: custom-field ids for the estimation point split (NUMBER fields).
# /estimate-ticket writes the Dev/QA points here instead of only in a comment.
# JIRA_DEV_POINTS_FIELD=customfield_xxxxx
# JIRA_QA_POINTS_FIELD=customfield_xxxxx
# Don't know the customfield ids? Run scripts/tracker/jira/discover-fields.sh — it lists
# the id + name for the Story/Developer/QA Points fields (or --all for every field). If
# these stay unset, upsert-ticket-details.sh --effort/--dev-points/--qa-points WARN and
# list the flag under "Skipped:" rather than silently dropping the value.

# ── Linear ───────────────────────────────────────────────────────────────────
# GraphQL API (https://api.linear.app/graphql). Auth with a personal API key.
# Create one: linear.app → Settings → Security & access → API → Personal API keys
# (starts with "lin_api_"). It is sent as-is in the Authorization header.
# LINEAR_API_KEY=<paste your personal key here>
# The TEAM key that prefixes issue identifiers, e.g. FM (→ FM-123). Lets a bare number
# (e.g. 123) expand to FM-123, and is the team new issues are created in (ref "new").
# On a full identifier / URL it is parsed from the id, so reads work without it.
# LINEAR_TEAM_KEY=FM
# Optional: override the GraphQL endpoint (default https://api.linear.app/graphql).
# LINEAR_API_URL=https://api.linear.app/graphql
# Optional: default PROJECT for newly-created issues (ref "new"). Linear issues have no
# project unless one is set, and there is no team-level "default project" via the API — so
# set it here. Give the project NAME (resolved case-insensitively) OR its id (the UUID in
# linear.app/…/project/<slug>-<ID>). LINEAR_PROJECT_ID wins if both are set.
# LINEAR_PROJECT=Feeed-me App
# LINEAR_PROJECT_ID=
#
# Linear notes:
#   • Descriptions AND comments are Markdown-native — sent verbatim (no ADF/blocks).
#   • --status names a workflow STATE (resolved to its id within the team). Map the org's
#     status names in workspace.config.yaml: tracker.statuses to your Linear state names.
#   • --priority: Urgent/High/Medium/Low/None (or a bare 0–4). Priority is an Int 0–4.
#   • ONE numeric `estimate` field (no Dev/QA split): --effort/--dev-points/--qa-points are
#     SUMMED into `estimate` (needs team estimation enabled in Linear).
#   • --issuetype and --component both map to LABELS (Linear has no issue-type field); a
#     missing label WARNs and is skipped. --parent sets the sub-issue's parent (--subtask is
#     a no-op). --link maps to an issue RELATION (related|blocks|duplicate; others → related).
