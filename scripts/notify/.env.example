# Copy to `.env` (this dir) and fill in. The .env is git-ignored.
# `aiworks sync` seeds NOTIFY_PROVIDER + NOTIFY_CHANNEL from workspace.config.yaml
# (notify.provider / notify.channel); you still add the secret below by hand.

# slack (the only provider today)
NOTIFY_PROVIDER=slack

# Default channel (id or #name) when send.sh is called without --channel.
# Mirrors workspace.config.yaml notify.channel.
# NOTIFY_CHANNEL=#reviews

# ── Slack auth — set ONE of these ─────────────────────────────────────────────
# Preferred: a bot token. Honours the target channel and returns a message permalink.
#   Needs the `chat:write` scope, and the bot must be a member of the channel.
# SLACK_BOT_TOKEN=xoxb-...

# Or: an Incoming Webhook URL. Simplest to set up, but the channel is FIXED by the
#   webhook config (NOTIFY_CHANNEL / --channel are ignored) and there is no permalink.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX
