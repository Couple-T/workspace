#!/usr/bin/env bash
#
# aiworks — the multi-repo agent workspace CLI.
#
# A thin wrapper over the per-repo lifecycle scripts. Run it from anywhere inside a
# workspace (it finds the workspace root by mani.yaml).
#
#   aiworks add    --url <git-url> [options]      # onboard one repo            (→ aiworks-add.sh)
#   aiworks sync   [<product>|<repo>] [options]   # onboard repos from config   (→ aiworks-sync.sh)
#   aiworks remove <repo>|--all    [options]   # offboard a repo (or all)    (→ aiworks-remove.sh)
#   aiworks config                 [options]   # regen the workflow CONFIG   (→ aiworks-config.sh)
#   aiworks setup                  [args…]     # workspace setup             (→ .superset/setup.sh)
#   aiworks run                    [args…]     # workspace run               (→ .superset/run.sh)
#   aiworks teardown               [args…]     # workspace teardown          (→ .superset/teardown.sh)
#   aiworks help | -h | --help
#
# setup / run / teardown are thin pass-throughs: they exec the matching .superset/<cmd>.sh
# at the workspace root verbatim, forwarding any extra args. No extra logic.
#
# Each subcommand has its own --help:  aiworks add -h  ·  aiworks sync -h  ·  aiworks remove -h
#
set -uo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"

usage() {
  cat <<'EOF'
aiworks — multi-repo agent workspace CLI

Usage:
  aiworks <command> [options]

Output is QUIET by default for sync / setup / run / teardown — only warnings, errors, and
the closing summary print. Pass -v/--verbose to any of them for the full step-by-step log.

Commands:
  add        Onboard ONE repo: register it (workspace.config.yaml products[] + mani.d +
             mani.yaml), clone it, build the codegraph index, install the agent skill packs,
             seed hooks/permissions, scaffold scripts/dev.sh, run the skill generator, and
             ensure the .superset lifecycle hooks (setup/run/teardown) exist + cover the repo.
  sync       Onboard every repo DECLARED in workspace.config.yaml products[].repos[]
             (optionally narrowed to one product, or one repo via a repo-name positional
             or --repo <name>) by running the `add` toolchain for each — reading
             url/kind/lang/distribute/path from the config. This is the fast path: add a
             repo's URL to the config, then `aiworks sync`. Idempotent: already-onboarded
             repos just SKIP. Use -n to preview. Also seeds the adapter .env files
             (scripts/{tracker,vcs}/.env) when missing — from .env.example, pre-filled with
             the providers/keys from workspace.config.yaml (an existing .env is left as-is) —
             and ensures the .superset lifecycle hooks (setup/run/teardown) cover every repo.
  remove     Offboard a repo (or every repo, with --all): deregister it from
             workspace.config.yaml products[].repos[], mani.d/<product>.yaml, mani.yaml and
             the .gitignore, unlink the workspace adapters (optionally --purge the clone).
  config     Regenerate the dev-cycle workflow's CONFIG block (.claude/workflows/dev-cycle.js)
             FROM workspace.config.yaml — the workflow can't read the FS at runtime, so it keeps
             an in-source mirror — AND the multi-root <workspace>.code-workspace `folders` array
             (one root per repo + the meta-repo, so VS Code/Cursor show each repo as its own
             Source Control panel; open it with `cursor <workspace>.code-workspace`). add /
             remove / sync run this automatically; run it yourself after hand-editing
             workspace.config.yaml (ticket_prefix, statuses, auto_merge, …).
  setup      Run the workspace setup hook: exec .superset/setup.sh verbatim (mani sync, seed
             adapter .env, link adapters into each repo + git-exclude the links so they never
             dirty the product repo). Pass-through — forwards any extra args.
  run        Run the workspace run hook: exec .superset/run.sh verbatim. Pass-through —
             forwards any extra args. (Errors clearly if .superset/run.sh does not exist.)
  teardown   Run the workspace teardown hook: exec .superset/teardown.sh verbatim (remove the
             cloned product repos). Pass-through — forwards any extra args.
  help       Show this help. Use `aiworks <command> -h` for a command's options.

Examples:
  # fast path — declare repos under products: in workspace.config.yaml, then:
  aiworks sync                          # onboard every repo in the config
  aiworks sync your-product --dry-run   # preview just the your-product product
  aiworks sync your-app                 # onboard ONLY the your-app repo (repo-name positional)
  aiworks sync --repo your-app,your-tests   # …or several named repos
  # or onboard one repo imperatively (also writes it into the config):
  aiworks add --url git@github.com:your-org/your-api.git --product backend --lang go
  aiworks remove your-api --purge    # deregister + delete the clone (refuses if dirty/unpushed)
  aiworks remove --all                  # offboard EVERY onboarded repo (config-only; keeps clones)
  aiworks remove --all --purge --force  # …and delete every clone too (force past dirty/unpushed)
  # workspace lifecycle — pass straight through to the .superset hooks:
  aiworks setup                         # exec .superset/setup.sh
  aiworks run                           # exec .superset/run.sh (scripts/dev.sh run per repo)
  aiworks run your-app                  # …run only the named repo(s)
  aiworks teardown                      # exec .superset/teardown.sh
EOF
}

# Pass-through to a .superset/<name>.sh hook at the workspace root, verbatim. The
# scripts/ dir always lives at <root>/scripts, so .superset is a sibling of $DIR.
superset_hook() {
  local name="$1"; shift
  local script="$DIR/../.superset/$name.sh"
  if [[ ! -f "$script" ]]; then
    printf 'aiworks %s: no hook found at %s\n' "$name" "$script" >&2
    printf '  create a .superset/%s.sh (see .superset/setup.sh for the pattern).\n' "$name" >&2
    exit 1
  fi
  if [[ -x "$script" ]]; then exec "$script" "$@"; else exec bash "$script" "$@"; fi
}

cmd="${1:-}"; [[ $# -gt 0 ]] && shift
case "$cmd" in
  add)            exec "$DIR/aiworks-add.sh" "$@" ;;
  sync)           exec "$DIR/aiworks-sync.sh" "$@" ;;
  remove|rm)      exec "$DIR/aiworks-remove.sh" "$@" ;;
  config)         exec "$DIR/aiworks-config.sh" "$@" ;;
  setup)          superset_hook setup "$@" ;;
  run)            superset_hook run "$@" ;;
  teardown)       superset_hook teardown "$@" ;;
  help|-h|--help|"") usage ;;
  *) printf 'aiworks: unknown command %q (try `aiworks help`)\n' "$cmd" >&2; exit 1 ;;
esac
