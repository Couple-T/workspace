{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledMcpjsonServers": [
    "postgres_main",
    "postgres_secondary",
    "sonarqube",
    "redis",
    "mcp-image"
  ],
  "permissions": {
    "allow": [
      "Bash(scripts/vcs/merge-pr.sh:*)",
      "Bash(../scripts/vcs/merge-pr.sh:*)",
      "Read",
      "Grep",
      "Glob",
      "Skill",
      "WebSearch",
      "WebFetch",
      "Edit",
      "Write",
      "Bash(git *)",
      "Bash(rtk *)",
      "Bash(mkdir *)",
      "Bash(codegraph *)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(npm test)",
      "Bash(npm test:*)",
      "Bash(pnpm install)",
      "Bash(pnpm run *)",
      "Bash(pnpm test:*)",
      "Bash(node test.js:*)",
      "Bash(node --version)",
      "Bash(scripts/dev.sh *)",
      "Bash(scripts/guard.sh *)",
      "Bash(scripts/perf.sh *)",
      "Bash(design-os/scripts/dos.sh *)",
      "Bash(*scripts/vcs/*)",
      "Bash(*scripts/tracker/*)",
      "Bash(*scripts/notify/*)",
      "Bash(sonar *)",
      "Bash(python3 .claude/skills/ui-ux-pro-max/scripts/search.py:*)",
      "Bash(python3 .claude/skills/summarize-workflow-performance/scripts/parse_workflow_usage.py:*)",
      "mcp__codegraph",
      "mcp__sonarqube",
      "mcp__postgres_secondary",
      "mcp__postgres_main",
      "mcp__redis",
      "mcp__claude_ai_Figma__get_screenshot",
      "mcp__claude_ai_Figma__get_metadata",
      "mcp__claude_ai_Figma__get_design_context",
      "mcp__claude_ai_Figma__get_variable_defs",
      "mcp__claude_ai_Figma__get_libraries",
      "mcp__claude_ai_Figma__search_design_system"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/*.pem)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/.aws/credentials)",
      "Read(**/secrets/**)",
      "Write(**/.env)",
      "Edit(**/.env)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".superset/mcp-services.sh up"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/resolve-language.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "command -v sonar >/dev/null 2>&1 || exit 0; sonar hook claude-pre-tool-use",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "command -v rtk >/dev/null 2>&1 || exit 0; rtk hook claude"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dev-wrapper/pretool-steer-build.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dev-wrapper/pretool-cd-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dev-wrapper/posttool-output-warden.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "command -v sonar >/dev/null 2>&1 || exit 0; sonar hook claude-prompt-submit",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/resolve-language.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  }
}
