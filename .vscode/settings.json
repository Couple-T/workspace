{
  "git.autoRepositoryDetection": true,
  "git.repositoryScanMaxDepth": 3,
  "search.useIgnoreFiles": false,
  "search.exclude": {
    "**/node_modules": true,
    "**/agent_logs": true,
    "**/.codegraph": true,
    "**/.aiworks": true,
    "**/.git": true,
    "**/dist": true,
    "**/coverage": true,
    "**/target": true,
    "**/.expo": true,
    "**/.env": true
  }
}
