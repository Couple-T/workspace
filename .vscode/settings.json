{
  "git.autoRepositoryDetection": true,
  "git.repositoryScanMaxDepth": 3,
  "search.useIgnoreFiles": false,
  "search.exclude": {
    "**/node_modules": true,
    "**/agent_logs": true,
    "**/.codegraph": true,
    "**/.aiworks": true,
    "**/.git": true,
    "**/dist": true,
    "**/coverage": true,
    "**/target": true,
    "**/.expo": true,
    "**/.env": false,
    "feeedme-app/build": true,
    "feeedme-app/.dart_tool": true,
    "feeedme-app/ios/Pods": true,
    "feeedme-app/android/.gradle": true
  }
}
