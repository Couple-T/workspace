httpd.pid
# mac osx files
.DS_Store

# node dependencies — installed from package.json + lockfile, never committed (any depth)
node_modules/

# environment files — ignore every .env (and .env.* local variants) at any depth,
# but keep the committed templates. Covers scripts/tracker/.env and scripts/vcs/.env.
.env
.env.*
!.env.example

# the org's real workspace config — each org creates it from workspace.config.example.yaml
workspace.config.yaml

# generated by `scripts/aiworks sync` from workspace.config.yaml
mani.d/
*.code-workspace

# python bytecode caches
__pycache__/

# .superset runtime state (pidfiles + service logs from run.sh)
.superset/run/
.superset/logs/

# the org's real product definitions — copy .superset/products/example.sh to <product-id>.sh
.superset/products/*.sh
!.superset/products/example.sh

# logs
agent_logs/
docs/brd/

# skill-creator scratch workspaces (eval sandboxes, skill snapshots, benchmark runs).
# Reproducible iteration artifacts — never committed to the workspace meta-repo.
.claude/skills/**/evals/
.claude/skills/*-workspace/

# settings.local.json backup written by `aiworks sync` when it preps the image-gen config
# (settings.local.json itself is ignored via the global gitignore).
.claude/settings.local.json.bak

# product repo clones (cloned by aiworks; not committed to the workspace meta-repo).
# `aiworks add` appends one `<repo-dir>/` line per onboarded repo below this comment,
# and `aiworks remove` drops it again — no hand-editing needed.
feeedme-app/
feeedme-appium/
