{
  "mcpServers": {
    "mcp-image": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-image"],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "IMAGE_OUTPUT_DIR": "${IMAGE_OUTPUT_DIR:-/tmp/aiworks-generated-images}",
        "IMAGE_QUALITY": "balanced"
      }
    },
    "sonarqube": {
      "command": "sonar",
      "args": ["run", "mcp"]
    },
    "postgres": {
      "type": "sse",
      "url": "http://localhost:25432/sse"
    },
    "redis": {
      "command": "uvx",
      "args": [
        "--from",
        "redis-mcp-server@latest",
        "redis-mcp-server",
        "--url",
        "redis://localhost:6379"
      ]
    }
  }
}
